        /* Premium Restaurant ERP Styling */
        :root {
            --gold-primary: #D4A017;
            --gold-light: #F4D03F;
            --navy-dark: #0F172A;
            --card-bg: #111827;
            --border-gold: rgba(212, 160, 23, 0.2);
        }
        
        .luxury-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
        }
        
        .glass-card {
            background: rgba(17, 24, 39, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-gold);
        }
        
        .gold-gradient {
            background: linear-gradient(135deg, #D4A017 0%, #F4D03F 50%, #D4A017 100%);
        }
        
        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            transition: all 0.2s;
            color: #9ca3af;
        }
        
        .nav-item:hover {
            background: rgba(212, 160, 23, 0.1);
            color: #F4D03F;
        }
        
        .nav-item.active {
            background: linear-gradient(135deg, rgba(212, 160, 23, 0.2) 0%, rgba(244, 208, 63, 0.2) 100%);
            border: 1px solid rgba(212, 160, 23, 0.3);
            color: #F4D03F;
            font-weight: 600;
        }
        
        .nav-sub-item {
            padding: 0.5rem 1rem 0.5rem 2.5rem;
            font-size: 0.875rem;
            color: #9ca3af;
            border-radius: 0.5rem;
            transition: all 0.2s;
        }
        
        .nav-sub-item:hover {
            background: rgba(212, 160, 23, 0.1);
            color: #F4D03F;
        }
        
        .nav-sub-item.active {
            background: rgba(212, 160, 23, 0.15);
            color: #F4D03F;
            font-weight: 600;
        }
        
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(30, 41, 59, 0.3);
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(212, 160, 23, 0.5);
            border-radius: 3px;
        }
        
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(212, 160, 23, 0.7);
        }
        
        [x-cloak] { display: none !important; }
        
        /* Ensure main content never goes under sidebar */
        @media (min-width: 1024px) {
            .main-content-wrapper {
                margin-left: 260px;
            }
        }
    </style>
</head>
